# Databricks ML serving endpoint. When unset, the app runs on deterministic stubs.
# Example: https://<workspace>.azuredatabricks.net/serving-endpoints/gulf-watch-v1/invocations
#
# Free-edition fallback — point at the local FastAPI server in databricks/server.py:
#   DATABRICKS_ENDPOINT_URL=http://localhost:8000/invocations
#   DATABRICKS_TOKEN=local-dev   # any non-empty string; the local server ignores it
DATABRICKS_ENDPOINT_URL=

# Personal access token for the Databricks workspace. Server-side only.
DATABRICKS_TOKEN=
